# Copier en .env — ne jamais committer le vrai .env !

# ── LLM (au moins une clé obligatoire) ───────────────────────────────────────

# Groq : GRATUIT — https://console.groq.com
# Modèle : llama-3.3-70b-versatile (provider principal)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI : ~$0.001/req — https://platform.openai.com
# Modèle : gpt-4o-mini (fallback automatique si Groq rate-limite)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RAG (optionnel — fallback local si absent) ────────────────────────────────
# Ragie : https://app.ragie.ai
RAGIE_API_KEY=ragie_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
